{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "project-rules config",
  "type": "object",
  "properties": {
    "rule_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "pattern": { "type": "string", "description": "Glob for rule files, e.g. **/AGENTS.md" },
          "sections": { "type": ["array", "null"], "items": { "type": "string" }, "description": "Restrict to named sections; null takes the whole file" }
        },
        "required": ["pattern", "sections"],
        "additionalProperties": false
      }
    },
    "precedence": {
      "type": "string",
      "enum": ["nearest-wins"],
      "description": "Only nearest-wins is defined; the field exists so a future strategy is explicit"
    },
    "compile_budget_tokens": {
      "type": "integer",
      "minimum": 200,
      "description": "Cap for the flattened block; overflow summarizes with pointers"
    }
  },
  "required": ["rule_files", "precedence", "compile_budget_tokens"],
  "additionalProperties": false
}
