{"name": "composes markdown with sections", "kind": "golden", "input": {"outline": "# Findings\nText.\n# Recommendations\nMore.", "output_path": "out/audit.md", "format": "markdown", "title": "Audit", "sections_required": null}, "expect": {"sections": ["Findings", "Recommendations"]}}
{"name": "required sections enforced ok", "kind": "golden", "input": {"outline": "# A\nx\n# B\ny", "output_path": "out/doc.md", "format": "markdown", "title": null, "sections_required": ["A", "B"]}, "expect": {"output_path": "out/doc.md"}}
{"name": "html format renders headings", "kind": "golden", "input": {"outline": "# One\nbody", "output_path": "out/doc.html", "format": "html", "title": "T", "sections_required": null}, "expect": {"output_path": "out/doc.html"}}
{"name": "missing required section fails loudly", "kind": "failure", "input": {"outline": "# A\nx", "output_path": "out/doc.md", "format": "markdown", "title": null, "sections_required": ["A", "Risks"]}, "expect": {"failure": "missing_required_section"}}
{"name": "headingless outline is typed", "kind": "failure", "input": {"outline": "just a blob of text", "output_path": "out/doc.md", "format": "markdown", "title": null, "sections_required": null}, "expect": {"failure": "invalid_outline"}}
