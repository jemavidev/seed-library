{"name": "dry-run lists pending without executing", "kind": "golden", "input": {"connection_ref": "app", "migrations_path": "db/migrations", "direction": "up", "target": null, "dry_run": true}, "expect": {"dry_run": true, "current_version_unchanged": true}}
{"name": "up applies in order", "kind": "golden", "input": {"connection_ref": "app", "migrations_path": "db/migrations", "direction": "up", "target": "0008", "dry_run": false}, "expect": {"applied_in_order": true, "current_version": "0008"}}
{"name": "down one step", "kind": "golden", "input": {"connection_ref": "app", "migrations_path": "db/migrations", "direction": "down", "target": null, "dry_run": false}, "expect": {"applied_count": 1}}
{"name": "edited history detected", "kind": "failure", "input": {"connection_ref": "app", "migrations_path": "fixtures/tampered", "direction": "up", "target": null, "dry_run": false}, "expect": {"failure": "checksum_mismatch"}}
{"name": "partial failure reports progress", "kind": "failure", "input": {"connection_ref": "app", "migrations_path": "fixtures/one-broken", "direction": "up", "target": null, "dry_run": false}, "expect": {"failure": "partial_failure", "applied_reported": true}}
