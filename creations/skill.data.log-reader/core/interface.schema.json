{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "log-reader input",
  "type": "object",
  "properties": {
    "source": {
      "type": "string",
      "description": "Configured log source name"
    },
    "pattern": {
      "type": ["string", "null"],
      "description": "Text or regex filter on the message; null = no message filter"
    },
    "since": {
      "type": "string",
      "description": "ISO-8601 timestamp or relative window like \"30m\", \"6h\", \"2d\""
    },
    "level": {
      "type": ["string", "null"],
      "enum": ["debug", "info", "warning", "error", "critical", null],
      "description": "Minimum severity; null returns all levels"
    },
    "max_lines": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5000,
      "description": "Hard cap on returned entries"
    }
  },
  "required": ["source", "pattern", "since", "level", "max_lines"],
  "additionalProperties": false
}
