{"name": "single recipient with attachment", "kind": "golden", "input": {"to": ["owner@acme.io"], "subject": "Q3 audit report", "body": "Attached the report.", "from_ref": "reports", "cc": null, "attachments": ["reports/audit.pdf"]}, "expect": {"accepted": ["owner@acme.io"], "rejected": []}}
{"name": "partial acceptance reported", "kind": "golden", "input": {"to": ["ok@acme.io", "bounce@dead.example"], "subject": "s", "body": "b", "from_ref": "reports", "cc": null, "attachments": null}, "expect": {"accepted": ["ok@acme.io"], "rejected": ["bounce@dead.example"]}}
{"name": "malformed address is typed", "kind": "failure", "input": {"to": ["not-an-email"], "subject": "s", "body": "b", "from_ref": "reports", "cc": null, "attachments": null}, "expect": {"failure": "invalid_recipient"}}
{"name": "recipient cap enforced", "kind": "failure", "input": {"to": ["<120 addresses>"], "subject": "s", "body": "b", "from_ref": "reports", "cc": null, "attachments": null}, "expect": {"failure": "recipient_cap_exceeded"}}
{"name": "missing attachment is typed", "kind": "failure", "input": {"to": ["ok@acme.io"], "subject": "s", "body": "b", "from_ref": "reports", "cc": null, "attachments": ["reports/does-not-exist.pdf"]}, "expect": {"failure": "attachment_not_found"}}
