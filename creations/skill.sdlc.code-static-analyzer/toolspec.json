{
  "id": "seed:sdlc:static-analyze",
  "name": "code-static-analyzer",
  "kind": "handwritten",
  "source": null,
  "parameters": { "$ref": "core/interface.schema.json" },
  "returns": {
    "type": "object",
    "properties": {
      "findings": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "rule": { "type": "string" },
            "severity": { "type": "string", "enum": ["info", "warning", "error"] },
            "file": { "type": "string" },
            "line": { "type": "integer" },
            "message": { "type": "string" }
          },
          "required": ["rule", "severity", "file", "line", "message"],
          "additionalProperties": false
        }
      },
      "summary": {
        "type": "object",
        "properties": {
          "error": { "type": "integer" },
          "warning": { "type": "integer" },
          "info": { "type": "integer" }
        },
        "required": ["error", "warning", "info"],
        "additionalProperties": false
      }
    },
    "required": ["findings", "summary"],
    "additionalProperties": false
  },
  "failures": [
    { "code": "analyzer_not_found", "retryable": false },
    { "code": "parse_error", "retryable": false }
  ],
  "credentials": [],
  "rateLimit": { "perMinute": 30, "burst": 10 },
  "idempotency": { "supported": true, "keyFrom": ["target_path", "analyzer", "severity_threshold"] },
  "mock": "core/evals/cases.jsonl",
  "capabilities": ["subprocess"],
  "cost": { "recorded": true, "account": "task" },
  "effects": "pure",
  "_meta": "_meta.json"
}
