{"name": "validate returns diagnostics not mutation", "kind": "golden", "input": {"service_ref": "edge-proxy", "action": "validate", "config_path": "conf/edge.conf", "version_ref": null}, "expect": {"valid": true, "no_mutation": true}}
{"name": "apply returns version handle", "kind": "golden", "input": {"service_ref": "edge-proxy", "action": "apply", "config_path": "conf/edge.conf", "version_ref": null}, "expect": {"version_ref_nonempty": true}}
{"name": "rollback restores kept version", "kind": "golden", "input": {"service_ref": "edge-proxy", "action": "rollback", "config_path": null, "version_ref": "cfg-30"}, "expect": {"action": "rollback"}}
{"name": "invalid config lists diagnostics", "kind": "failure", "input": {"service_ref": "edge-proxy", "action": "validate", "config_path": "fixtures/broken.conf", "version_ref": null}, "expect": {"failure": "config_invalid", "diagnostics_nonempty": true}}
{"name": "unvalidated apply refused", "kind": "failure", "input": {"service_ref": "edge-proxy", "action": "apply", "config_path": "conf/never-validated.conf", "version_ref": null}, "expect": {"failure": "apply_unvalidated"}}
{"name": "failed reload auto-reverts", "kind": "failure", "input": {"service_ref": "edge-proxy", "action": "apply", "config_path": "fixtures/valid-but-fatal.conf", "version_ref": null}, "expect": {"failure": "reload_failed", "prior_version_restored": true}}
