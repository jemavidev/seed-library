{"name": "compress explicit paths", "kind": "golden", "input": {"action": "compress", "archive_path": "out/bundle.zip", "paths": ["src/", "README.md"], "format": "zip", "dest_path": null}, "expect": {"output_path": "out/bundle.zip", "entries_count_at_least": 2}}
{"name": "list without extracting", "kind": "golden", "input": {"action": "list", "archive_path": "fixtures/ok.tar.gz", "paths": null, "format": "auto", "dest_path": null}, "expect": {"action": "list", "entries_count_at_least": 1}}
{"name": "extract to explicit dest", "kind": "golden", "input": {"action": "extract", "archive_path": "fixtures/ok.tar.gz", "paths": null, "format": "auto", "dest_path": "out/unpacked"}, "expect": {"output_path": "out/unpacked"}}
{"name": "zip-slip is blocked atomically", "kind": "failure", "input": {"action": "extract", "archive_path": "fixtures/evil-slip.zip", "paths": null, "format": "zip", "dest_path": "out/unpacked"}, "expect": {"failure": "path_escape_blocked", "nothing_extracted": true}}
{"name": "corrupt archive is typed", "kind": "failure", "input": {"action": "list", "archive_path": "fixtures/truncated.zip", "paths": null, "format": "zip", "dest_path": null}, "expect": {"failure": "corrupt_archive"}}
