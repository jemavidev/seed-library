{"name": "read returns content without revision bump", "kind": "golden", "input": {"document_ref": "weekly-status", "action": "read", "content": null, "range_ref": null, "title": null}, "expect": {"content_nonempty": true, "revision_unchanged": true}}
{"name": "append returns new revision", "kind": "golden", "input": {"document_ref": "weekly-status", "action": "append", "content": "## Week 27\nAll green.", "range_ref": null, "title": null}, "expect": {"revision_id_nonempty": true}}
{"name": "replace named range only touches range", "kind": "golden", "input": {"document_ref": "weekly-status", "action": "replace-range", "content": "Status: amber", "range_ref": "current-status", "title": null}, "expect": {"rest_of_document_unchanged": true}}
{"name": "create needs title", "kind": "golden", "input": {"document_ref": null, "action": "create", "content": "# Kickoff\n…", "range_ref": null, "title": "Project Kickoff"}, "expect": {"document_ref_nonempty": true}}
{"name": "concurrent edit conflict is typed", "kind": "failure", "input": {"document_ref": "weekly-status", "action": "replace-range", "content": "x", "range_ref": "stale-anchor", "title": null}, "expect": {"failure": "conflict", "retryable": true}}
{"name": "unknown range is typed", "kind": "failure", "input": {"document_ref": "weekly-status", "action": "replace-range", "content": "x", "range_ref": "no-such-range", "title": null}, "expect": {"failure": "range_not_found"}}
