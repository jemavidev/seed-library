{
  "id": "seed:saas:workspace-document-operator",
  "name": "workspace-document-operator",
  "kind": "handwritten",
  "source": null,
  "parameters": { "$ref": "core/interface.schema.json" },
  "returns": {
    "type": "object",
    "properties": {
      "action": { "type": "string" },
      "document_ref": { "type": "string" },
      "revision_id": { "type": ["string", "null"] },
      "content": { "type": ["string", "null"] }
    },
    "required": ["action", "document_ref", "revision_id", "content"],
    "additionalProperties": false
  },
  "failures": [
    { "code": "document_not_found", "retryable": false },
    { "code": "permission_denied", "retryable": false },
    { "code": "range_not_found", "retryable": false },
    { "code": "conflict", "retryable": true },
    { "code": "auth_failed", "retryable": false }
  ],
  "credentials": [
    { "name": "WORKSPACE_SUITE_TOKEN", "env": "WORKSPACE_SUITE_TOKEN" }
  ],
  "rateLimit": { "perMinute": 30, "burst": 10 },
  "idempotency": { "supported": true, "keyFrom": ["document_ref", "action", "range_ref", "content"] },
  "mock": "core/evals/cases.jsonl",
  "capabilities": ["network-egress"],
  "cost": { "recorded": true, "account": "task" },
  "effects": "external",
  "compensate": {
    "summary": "restore the document to the revision preceding the recorded revision_id via the suite's revision history",
    "toolId": "seed:saas:workspace-document-operator"
  },
  "_meta": "_meta.json"
}
